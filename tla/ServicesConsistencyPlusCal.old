                                                      /\ UNCHANGED <<restarted, anyRestarted>>
                                                   \/ /\ restarted' = [restarted EXCEPT ![self] = TRUE]
                                                      /\ anyRestarted' = TRUE
                                                      /\ pc' = [pc EXCEPT ![self] = "Start_"]
                                           ELSE /\ pc' = [pc EXCEPT ![self] = "ProcessMessageCheckoutStockContinuation"]
                                                /\ UNCHANGED << restarted, 
