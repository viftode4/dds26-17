                                /\ IF restarted[self] = FALSE /\ anyRestarted = FALSE
                                      THEN /\ \/ /\ TRUE
                                                 /\ pc' = [pc EXCEPT ![self] = "ReplyCheckoutResponse"]
                                                 /\ UNCHANGED <<restarted, anyRestarted>>
                                              \/ /\ restarted' = [restarted EXCEPT ![self] = TRUE]
                                                 /\ anyRestarted' = TRUE
