                                     \/ /\ restarted' = [restarted EXCEPT ![self] = TRUE]
                                        /\ anyRestarted' = TRUE
                                        /\ pc' = [pc EXCEPT ![self] = "Start"]
                             ELSE /\ pc' = [pc EXCEPT ![self] = "AbortPending"]
                                  /\ UNCHANGED << restarted, anyRestarted >>
                       /\ UNCHANGED << done, userCredits, userHeldCredits, 
                                       userPaidCredits, stockAvailable, 
