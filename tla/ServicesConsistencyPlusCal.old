                                /\ pc' = [pc EXCEPT ![self] = "step"]
                                /\ UNCHANGED << done, userCredits, 
                                                userHeldCredits, 
                                                userPaidCredits, 
                                                stockAvailable, stockHeld, 
                                                stockSold, paymentStatus, 
                                                stockStatus, orchestratorTxP, 
                                                orchestratorTxS, 
