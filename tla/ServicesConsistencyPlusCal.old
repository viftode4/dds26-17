Cont6(self) == /\ pc[self] = "Cont6"
               /\ checkoutStatus' = [checkoutStatus EXCEPT ![self] = <<"aborting", "aborting">>]
               /\ pc' = [pc EXCEPT ![self] = "CheckoutProcess"]
               /\ UNCHANGED << done, userCredits, userHeldCredits, 
